import matplotlib.pyplot as plt
import numpy as np
import pandas as pd
import yfinance as yf

from sklearn.linear_model import LogisticRegression
from sklearn.metrics import accuracy_score, classification_report, confusion_matrix
from sklearn.preprocessing import StandardScaler
from sklearn.tree import DecisionTreeClassifier

import nltk
from nltk.sentiment import SentimentIntensityAnalyzer

warnings.filterwarnings("ignore")
pd.set_option("display.max_columns", 50)
pd.set_option("display.width", 120)


def ensure_vader_lexicon() -> bool:
	"""Download VADER lexicon if not available. Returns True if ready."""
	try:
		nltk.data.find("sentiment/vader_lexicon.zip")
		return True
	except LookupError:
		try:
			print("VADER lexicon not found. Downloading now...")
			nltk.download("vader_lexicon", quiet=True)
			nltk.data.find("sentiment/vader_lexicon.zip")
			return True
		except Exception as exc:
			print(f"Could not download VADER lexicon: {exc}")
			return False


# -----------------------------------
# SECTION 2: DOWNLOAD TSLA STOCK DATA
# -----------------------------------
# This section downloads TSLA data from Yahoo Finance and keeps useful columns.

def load_stock_data(start_date: str = "2022-01-01", end_date: str = "2024-12-31") -> pd.DataFrame:
	"""Download TSLA daily stock data and return a clean DataFrame."""
	print("\nLoading TSLA stock data...")
	try:
		stock_df = yf.download("TSLA", start=start_date, end=end_date, progress=False)
		if stock_df.empty:
			print("No stock data returned. Check internet connection or date range.")
			return pd.DataFrame()

		stock_df = stock_df[["Open", "High", "Low", "Close", "Volume"]].copy()
		stock_df = stock_df.reset_index()
		stock_df["Date"] = pd.to_datetime(stock_df["Date"]).dt.floor("D")
		stock_df = stock_df.sort_values("Date").reset_index(drop=True)

		print(f"Loaded {len(stock_df)} rows of TSLA stock data.")
		return stock_df
	except Exception as exc:
		print(f"Error while downloading stock data: {exc}")
		return pd.DataFrame()


# --------------------------------
# SECTION 3: CREATE STOCK FEATURES
# --------------------------------
# This section creates returns, moving averages, and the target variable.

def build_stock_features(stock_df: pd.DataFrame) -> pd.DataFrame:
	"""Create beginner-friendly stock features and binary target."""
	if stock_df.empty:
		return pd.DataFrame()

	df = stock_df.copy()

	# Current-day return based on close-to-close percentage change
	df["daily_return"] = df["Close"].pct_change()

	# Next-day return used for analysis and plotting
	df["next_day_return"] = df["Close"].shift(-1) / df["Close"] - 1

	# Binary target: 1 if next day close is higher, else 0
	df["target"] = (df["Close"].shift(-1) > df["Close"]).astype(int)

	# Simple rolling features
	df["ma_3"] = df["Close"].rolling(window=3).mean()
	df["ma_7"] = df["Close"].rolling(window=7).mean()
	df["vol_avg_3"] = df["Volume"].rolling(window=3).mean()

	# Drop rows with missing values from rolling windows and shifted target/return
	df = df.dropna().reset_index(drop=True)

	print("\nStock features created. Preview:")
	print(df.head())
	return df


# -------------------------------------------
# SECTION 4: LOAD OR CREATE WALLSTREETBETS DATA
# -------------------------------------------
# This section loads WSB CSV data if available and prepares post-level text.

def load_wsb_data(csv_path: str = "wsb_tsla_posts.csv") -> pd.DataFrame:
	"""
	Load WSB post data from CSV.
	Expected columns can include: date, title, body, score, num_comments.
	The function is robust if some optional columns are missing.
	"""
	print("\nLoading WallStreetBets data...")

	if not os.path.exists(csv_path):
		print(
			f"WSB CSV not found at '{csv_path}'. Continuing with stock-only pipeline. "
			"Add the file later to include sentiment features."
		)
		return pd.DataFrame()

	try:
		wsb_df = pd.read_csv(csv_path)
		if wsb_df.empty:
			print("WSB CSV exists but contains no rows. Continuing without Reddit features.")
			return pd.DataFrame()

		# Normalize column names to lower case for easier handling
		wsb_df.columns = [c.strip().lower() for c in wsb_df.columns]

		if "date" not in wsb_df.columns:
			print("WSB CSV is missing required 'date' column. Continuing without Reddit features.")
			return pd.DataFrame()

		wsb_df["date"] = pd.to_datetime(wsb_df["date"], errors="coerce").dt.floor("D")
		wsb_df = wsb_df.dropna(subset=["date"]).copy()

		# Safely handle missing text columns
		if "title" not in wsb_df.columns:
			wsb_df["title"] = ""
		if "body" not in wsb_df.columns:
			wsb_df["body"] = ""

		wsb_df["title"] = wsb_df["title"].fillna("").astype(str)
		wsb_df["body"] = wsb_df["body"].fillna("").astype(str)
		wsb_df["text"] = (wsb_df["title"] + " " + wsb_df["body"]).str.strip()

		# Keep optional numeric columns if they exist
		for col in ["score", "num_comments"]:
			if col in wsb_df.columns:
				wsb_df[col] = pd.to_numeric(wsb_df[col], errors="coerce")

		print(f"Loaded {len(wsb_df)} WSB posts.")
		return wsb_df
	except Exception as exc:
		print(f"Error while loading WSB data: {exc}")
		return pd.DataFrame()


# ------------------------------
# SECTION 5: SENTIMENT ANALYSIS
# ------------------------------
# This section computes VADER sentiment per post and aggregates by day.

def compute_sentiment(wsb_df: pd.DataFrame, vader_ready: bool) -> pd.DataFrame:
	"""Compute per-post sentiment and aggregate into daily Reddit features."""
	if wsb_df.empty:
		return pd.DataFrame()

	if not vader_ready:
		print("VADER is unavailable, so sentiment is skipped.")
		return pd.DataFrame()

	try:
		sia = SentimentIntensityAnalyzer()
	except Exception as exc:
		print(f"Could not initialize SentimentIntensityAnalyzer: {exc}")
		return pd.DataFrame()

	df = wsb_df.copy()

	# Compute compound sentiment for each post
	def get_compound_score(text: str) -> float:
		if not isinstance(text, str) or not text.strip():
			return 0.0
		return sia.polarity_scores(text)["compound"]

	df["compound"] = df["text"].apply(get_compound_score)

	# Aggregate post-level data into daily features
	agg_dict = {
		"compound": "mean",
		"text": "count",
	}
	if "score" in df.columns:
		agg_dict["score"] = "mean"
	if "num_comments" in df.columns:
		agg_dict["num_comments"] = "mean"

	daily = df.groupby("date", as_index=False).agg(agg_dict)
	daily = daily.rename(
		columns={
			"date": "Date",
			"compound": "avg_sentiment",
			"text": "post_count",
			"score": "avg_score",
			"num_comments": "avg_num_comments",
		}
	)

	print("\nDaily Reddit summary sample:")
	print(daily.head())
	return daily


# -----------------------------------------------
# SECTION 6: MERGE STOCK DATA WITH REDDIT DATA
# -----------------------------------------------
# This section merges daily stock and Reddit features by date.

def merge_datasets(stock_features_df: pd.DataFrame, reddit_daily_df: pd.DataFrame) -> pd.DataFrame:
	"""Left-join Reddit daily features onto stock data and fill missing values."""
	if stock_features_df.empty:
		return pd.DataFrame()

	merged_df = stock_features_df.copy()

	if not reddit_daily_df.empty:
		merged_df = merged_df.merge(reddit_daily_df, on="Date", how="left")
	else:
		# If Reddit data does not exist, create empty columns so pipeline still runs
		merged_df["avg_sentiment"] = 0.0
		merged_df["post_count"] = 0.0

	# Fill reasonable missing Reddit values with 0
	for col in ["avg_sentiment", "post_count", "avg_score", "avg_num_comments"]:
		if col in merged_df.columns:
			merged_df[col] = merged_df[col].fillna(0)

	print(f"\nMerged dataset shape: {merged_df.shape}")
	print(merged_df.head())
	return merged_df


# ---------------------------------
# SECTION 7: EXPLORATORY DATA ANALYSIS
# ---------------------------------
# This section creates simple matplotlib charts for quick understanding.

def run_eda(merged_df: pd.DataFrame) -> None:
	"""Create beginner-friendly EDA plots using matplotlib."""
	if merged_df.empty:
		print("No data available for EDA plots.")
		return

	# Plot 1: TSLA closing price over time
	plt.figure(figsize=(10, 4))
	plt.plot(merged_df["Date"], merged_df["Close"])
	plt.title("TSLA Closing Price Over Time")
	plt.xlabel("Date")
	plt.ylabel("Close Price (USD)")
	plt.tight_layout()
	plt.show()

	# Plot 2: Histogram of daily returns
	plt.figure(figsize=(8, 4))
	plt.hist(merged_df["daily_return"], bins=40)
	plt.title("Distribution of TSLA Daily Returns")
	plt.xlabel("Daily Return")
	plt.ylabel("Frequency")
	plt.tight_layout()
	plt.show()

	# Plot 3: Daily sentiment over time (if available)
	if "avg_sentiment" in merged_df.columns:
		plt.figure(figsize=(10, 4))
		plt.plot(merged_df["Date"], merged_df["avg_sentiment"])
		plt.title("Average Daily WallStreetBets Sentiment")
		plt.xlabel("Date")
		plt.ylabel("Average Sentiment (Compound)")
		plt.tight_layout()
		plt.show()

	# Plot 4: Sentiment vs next-day return
	if "avg_sentiment" in merged_df.columns:
		plt.figure(figsize=(7, 5))
		plt.scatter(merged_df["avg_sentiment"], merged_df["next_day_return"], alpha=0.6)
		plt.title("Daily Sentiment vs Next-Day Return")
		plt.xlabel("Average Daily Sentiment")
		plt.ylabel("Next-Day Return")
		plt.tight_layout()
		plt.show()


# -------------------------------------
# SECTION 8: PREPARE DATA FOR MODELING
# -------------------------------------
# This section defines features/target and uses a time-based train-test split.

def prepare_model_data(
	merged_df: pd.DataFrame,
	feature_cols: Optional[List[str]] = None,
	train_ratio: float = 0.8,
) -> Tuple[pd.DataFrame, pd.DataFrame, pd.Series, pd.Series, List[str]]:
	"""Prepare X and y using time-based split and no shuffling."""
	if merged_df.empty:
		return pd.DataFrame(), pd.DataFrame(), pd.Series(dtype=int), pd.Series(dtype=int), []

	if feature_cols is None:
		feature_cols = ["daily_return", "ma_3", "ma_7", "vol_avg_3", "avg_sentiment", "post_count"]

	df = merged_df.copy()

	# Ensure all requested features exist
	for col in feature_cols:
		if col not in df.columns:
			df[col] = 0.0

	model_df = df.dropna(subset=feature_cols + ["target"]).copy()

	X = model_df[feature_cols]
	y = model_df["target"].astype(int)

	split_index = int(len(model_df) * train_ratio)
	X_train = X.iloc[:split_index].copy()
	X_test = X.iloc[split_index:].copy()
	y_train = y.iloc[:split_index].copy()
	y_test = y.iloc[split_index:].copy()

	print(
		f"\nTrain size: {len(X_train)} rows | Test size: {len(X_test)} rows "
		f"(Time-based split, no shuffle)"
	)
	return X_train, X_test, y_train, y_test, feature_cols


# --------------------------
# SECTION 9: BASELINE MODEL
# --------------------------
# This section creates a very simple baseline using majority class prediction.

def evaluate_baseline(y_train: pd.Series, y_test: pd.Series) -> Dict[str, float]:
	"""Baseline: predict the majority class from training data."""
	if y_train.empty or y_test.empty:
		print("Not enough data for baseline evaluation.")
		return {"baseline_accuracy": np.nan, "majority_class": np.nan}

	majority_class = int(y_train.mode().iloc[0])
	baseline_preds = np.full(shape=len(y_test), fill_value=majority_class)
	baseline_acc = accuracy_score(y_test, baseline_preds)

	print("\nBaseline model (majority class):")
	print(f"Majority class in training data: {majority_class}")
	print(f"Baseline accuracy: {baseline_acc:.4f}")

	return {"baseline_accuracy": baseline_acc, "majority_class": majority_class}


# --------------------------------------
# SECTION 10 & 11: TRAIN BEGINNER MODELS
# --------------------------------------
# This section trains Logistic Regression and Decision Tree, then compares performance.

def train_models(
	X_train: pd.DataFrame,
	X_test: pd.DataFrame,
	y_train: pd.Series,
	y_test: pd.Series,
) -> Tuple[Optional[LogisticRegression], Optional[DecisionTreeClassifier], Dict[str, float], Optional[StandardScaler]]:
	"""Train Logistic Regression and Decision Tree, print metrics, and return models."""
	if X_train.empty or X_test.empty:
		print("Not enough data to train models.")
		return None, None, {"logistic_accuracy": np.nan, "tree_accuracy": np.nan}, None

	# Scale features for Logistic Regression
	scaler = StandardScaler()
	X_train_scaled = scaler.fit_transform(X_train)
	X_test_scaled = scaler.transform(X_test)

	# Logistic Regression
	log_model = LogisticRegression(max_iter=1000, random_state=42)
	log_model.fit(X_train_scaled, y_train)
	log_preds = log_model.predict(X_test_scaled)

	log_acc = accuracy_score(y_test, log_preds)
	log_cm = confusion_matrix(y_test, log_preds)

	print("\nLogistic Regression Results:")
	print(f"Accuracy: {log_acc:.4f}")
	print("Confusion Matrix:")
	print(log_cm)
	print("Classification Report:")
	print(classification_report(y_test, log_preds, digits=4))

	# Decision Tree Classifier (simple settings for beginners)
	tree_model = DecisionTreeClassifier(max_depth=4, min_samples_leaf=10, random_state=42)
	tree_model.fit(X_train, y_train)
	tree_preds = tree_model.predict(X_test)

	tree_acc = accuracy_score(y_test, tree_preds)

	print("\nDecision Tree Results:")
	print(f"Accuracy: {tree_acc:.4f}")

	print("\nAccuracy Comparison:")
	print(f"Logistic Regression Accuracy: {log_acc:.4f}")
	print(f"Decision Tree Accuracy:       {tree_acc:.4f}")

	scores = {
		"logistic_accuracy": log_acc,
		"tree_accuracy": tree_acc,
	}
	return log_model, tree_model, scores, scaler


# --------------------------------------------
# SECTION 12: FEATURE IMPORTANCE / INTERPRETATION
# --------------------------------------------
# This section prints readable coefficient/importance tables.

def interpret_models(
	log_model: Optional[LogisticRegression],
	tree_model: Optional[DecisionTreeClassifier],
	feature_cols: List[str],
) -> None:
	"""Print feature interpretation for Logistic Regression and Decision Tree."""
	if log_model is not None:
		coef_df = pd.DataFrame(
			{
				"feature": feature_cols,
				"logistic_coefficient": log_model.coef_[0],
			}
		)
		coef_df["abs_coefficient"] = coef_df["logistic_coefficient"].abs()
		coef_df = coef_df.sort_values("abs_coefficient", ascending=False).reset_index(drop=True)

		print("\nLogistic Regression Coefficients (larger absolute value = stronger influence):")
		print(coef_df[["feature", "logistic_coefficient"]])

	if tree_model is not None:
		imp_df = pd.DataFrame(
			{
				"feature": feature_cols,
				"tree_importance": tree_model.feature_importances_,
			}
		).sort_values("tree_importance", ascending=False)

		print("\nDecision Tree Feature Importances:")
		print(imp_df)


# --------------------------------
# SECTION 13: FINAL SUMMARY OUTPUT
# --------------------------------
# This section prints a short report-style summary in plain English.

def print_final_summary(
	merged_df: pd.DataFrame,
	feature_cols: List[str],
	baseline_info: Dict[str, float],
	model_scores: Dict[str, float],
) -> None:
	"""Print a student-friendly final summary."""
	print("\n" + "=" * 70)
	print("FINAL SUMMARY")
	print("=" * 70)

	dataset_size = len(merged_df)
	baseline_acc = baseline_info.get("baseline_accuracy", np.nan)
	log_acc = model_scores.get("logistic_accuracy", np.nan)
	tree_acc = model_scores.get("tree_accuracy", np.nan)

	print(f"Dataset size (rows after feature engineering): {dataset_size}")
	print(f"Features used: {', '.join(feature_cols)}")
	print(f"Baseline accuracy: {baseline_acc:.4f}")
	print(f"Logistic Regression accuracy: {log_acc:.4f}")
	print(f"Decision Tree accuracy: {tree_acc:.4f}")

	if np.isfinite(log_acc) and np.isfinite(baseline_acc):
		if log_acc > baseline_acc:
			sentiment_note = (
				"The model with Reddit features performed better than baseline, "
				"so sentiment/activity may have some useful signal."
			)
		else:
			sentiment_note = (
				"The model did not clearly beat baseline, so sentiment may be weak "
				"or we may need more/better Reddit data and features."
			)
	else:
		sentiment_note = (
			"Model comparison is incomplete. Check data availability and rerun the pipeline."
		)

	print("\nPlain-English conclusion:")
	print(sentiment_note)


# --------------------------------
# MAIN EXECUTION: RUN FULL PIPELINE
# --------------------------------

def main() -> None:
	# Easy-to-edit date range
	start_date = "2022-01-01"
	end_date = "2024-12-31"

	# Step 1: setup VADER
	vader_ready = ensure_vader_lexicon()

	# Step 2-3: stock data and stock features
	stock_df = load_stock_data(start_date=start_date, end_date=end_date)
	stock_features_df = build_stock_features(stock_df)

	if stock_features_df.empty:
		print("Stock feature dataset is empty. Stopping pipeline.")
		return

	# Step 4-5: WSB data and sentiment features
	wsb_posts_df = load_wsb_data(csv_path="wsb_tsla_posts.csv")
	reddit_daily_df = compute_sentiment(wsb_posts_df, vader_ready=vader_ready)

	# Step 6: merge
	merged_df = merge_datasets(stock_features_df, reddit_daily_df)

	# Step 7: EDA charts
	run_eda(merged_df)

	# Step 8: modeling data prep
	X_train, X_test, y_train, y_test, feature_cols = prepare_model_data(merged_df)

	# Step 9: baseline
	baseline_info = evaluate_baseline(y_train, y_test)

	# Step 10-11: train models
	log_model, tree_model, model_scores, _ = train_models(X_train, X_test, y_train, y_test)

	# Step 12: interpretation
	interpret_models(log_model, tree_model, feature_cols)

	# Step 13: final summary
	print_final_summary(merged_df, feature_cols, baseline_info, model_scores)


if __name__ == "__main__":
	main()


